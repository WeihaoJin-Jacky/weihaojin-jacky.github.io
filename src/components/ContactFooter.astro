---
import { profile } from '../data/site';
import LinkChip from './LinkChip.astro';

const footerLinks = [...profile.contact, ...(profile.cv ? [profile.cv] : [])];
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="inner">
    <p class="invite">
      Interested in research collaboration or hiring? The fastest way to reach me is by email.
    </p>
    <ul class="links" role="list">
      {
        footerLinks.map((link) => (
          <li>
            <LinkChip link={link} />
          </li>
        ))
      }
    </ul>
    <p class="colophon">© {currentYear} {profile.name} · Built with Astro</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--line);
    margin-top: var(--space-6);
  }

  .inner {
    max-width: var(--page-max);
    margin-inline: auto;
    padding: var(--space-6) var(--page-pad);
  }

  .invite {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    max-width: 80ch;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
  }

  .colophon {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin-top: var(--space-5);
  }
</style>
