---
import { profile } from '../data/site';
import HeroCanvas from './HeroCanvas.astro';
import LinkChip from './LinkChip.astro';
import ProfilePhoto from './ProfilePhoto.astro';

const heroLinks = [...profile.contact, ...(profile.cv ? [profile.cv] : [])];
---

<section class="hero">
  <HeroCanvas />
  <div class="scrim" aria-hidden="true"></div>

  <div class="content">
    <ProfilePhoto />
    <h1>{profile.name}</h1>
    <p class="tagline">{profile.tagline}</p>
    <ul class="links" role="list">
      {
        heroLinks.map((link) => (
          <li>
            <LinkChip link={link} />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
  }

  .scrim {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to bottom, transparent 55%, var(--paper)),
      radial-gradient(ellipse 60% 70% at 30% 50%, var(--paper) 25%, transparent 75%);
  }

  .content {
    position: relative;
    max-width: var(--page-max);
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--page-pad);
    padding-block: clamp(5rem, 14vh, 7.5rem) clamp(3rem, 8vh, 4.5rem);
  }

  h1 {
    font-size: var(--text-hero);
    margin-top: var(--space-4);
  }

  .tagline {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    margin-top: var(--space-3);
    max-width: 44ch;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
  }
</style>
