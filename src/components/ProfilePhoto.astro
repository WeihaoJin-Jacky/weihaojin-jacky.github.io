---
import { profile } from '../data/site';

const hasPhoto = profile.photo !== null;
---

{
  hasPhoto ? (
    <img class="portrait" src={profile.photo} alt={`Portrait of ${profile.name}`} width="132" height="132" />
  ) : (
    <div class="portrait monogram" role="img" aria-label={`Placeholder portrait for ${profile.name}`}>
      {profile.monogram}
    </div>
  )
}

<style>
  .portrait {
    width: 8.25rem;
    height: 8.25rem;
    border-radius: 50%;
    border: 1px solid var(--line);
    object-fit: cover;
  }

  .monogram {
    display: grid;
    place-items: center;
    background: var(--accent-wash);
    color: var(--accent);
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    letter-spacing: 0.04em;
    user-select: none;
  }
</style>
