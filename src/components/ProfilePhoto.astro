---
import { profile } from '../data/site';

// Resolve the public/ file against the deploy base path (favicon does the same),
// so the image loads whether served at the root or a project subpath.
const photoSrc = profile.photo ? import.meta.env.BASE_URL + profile.photo.replace(/^\//, '') : null;
---

{
  photoSrc ? (
    <img class="portrait" src={photoSrc} alt={`Portrait of ${profile.name}`} width="132" height="132" />
  ) : (
    <div class="portrait monogram" role="img" aria-label={`Placeholder portrait for ${profile.name}`}>
      {profile.monogram}
    </div>
  )
}

<style>
  .portrait {
    width: 8.25rem;
    height: 8.25rem;
    border-radius: 50%;
    border: 1px solid var(--line);
    object-fit: cover;
  }

  .monogram {
    display: grid;
    place-items: center;
    background: var(--accent-wash);
    color: var(--accent);
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    letter-spacing: 0.04em;
    user-select: none;
  }
</style>
